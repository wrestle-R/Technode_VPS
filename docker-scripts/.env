APP_IMAGE=wrestle66/technode-app:latest
WORKER_IMAGE=wrestle66/technode-worker:latest
POSTGRES_IMAGE=wrestle66/technode-postgres:latest
MQTT_IMAGE=eclipse-mosquitto:2

# Optional if you want to use script defaults for publish commands
DOCKERHUB_NAMESPACE=wrestle66
DOCKERHUB_TAG=latest

APP_CONTAINER=technode-app
WORKER_CONTAINER=technode-worker
POSTGRES_CONTAINER=technode-postgres
MQTT_CONTAINER=mqtt

NETWORK_NAME=technode-net
POSTGRES_VOLUME=technode-pgdata

APP_PORT=3000
POSTGRES_HOST_PORT=5432
MQTT_HOST_PORT=1883

POSTGRES_DB=technode_vps
POSTGRES_USER=technode
POSTGRES_PASSWORD=change-this-db-password

NEXT_PUBLIC_APP_URL=http://195.35.22.74:3000
APP_HEALTHCHECK_URL=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

PRISMA_DATABASE_URL=postgresql://technode:change-this-db-password@technode-postgres:5432/technode_vps?schema=public
MQTT_BROKER_URL=mqtt://mqtt:1883
