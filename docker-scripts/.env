# Copy this file to docker-scripts/.env and adjust values for your machine or VPS.

APP_IMAGE=technode/app:dev
WORKER_IMAGE=technode/worker:dev
POSTGRES_IMAGE=technode/postgres:dev
MQTT_IMAGE=eclipse-mosquitto:2

APP_CONTAINER=technode-app
WORKER_CONTAINER=technode-worker
POSTGRES_CONTAINER=technode-postgres
MQTT_CONTAINER=mosquitto

NETWORK_NAME=technode-net
POSTGRES_VOLUME=technode-pgdata

APP_PORT=3000
POSTGRES_HOST_PORT=
MQTT_HOST_PORT=

POSTGRES_DB=technode_vps
POSTGRES_USER=technode
POSTGRES_PASSWORD=technodepass

NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_HEALTHCHECK_URL=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional override if app/worker should use a different DB host.
# PRISMA_DATABASE_URL=postgresql://technode:technodepass@technode-postgres:5432/technode_vps?schema=public

# Optional override if worker should use a different broker URL.
# MQTT_BROKER_URL=mqtt://mosquitto:1883
