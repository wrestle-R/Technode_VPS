{
  "name": "next",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:prepare && next dev --turbopack",
    "build": "npm run prisma:prepare && next build",
    "start": "next start",
    "ems:mqtt": "tsx scripts/ems-mqtt-worker.ts",
    "lint": "eslint",
    "prisma:prepare": "prisma generate && prisma migrate deploy && npm run bootstrap:tenant",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "bootstrap:tenant": "tsx scripts/bootstrap-default-company.ts",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@prisma/client": "^6.18.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "mqtt": "^5.15.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "prisma": "^6.18.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
