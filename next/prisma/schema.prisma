generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model Company {
  company_id            Int      @id @default(autoincrement())
  name                  String   @db.VarChar(100)
  slug                  String   @unique @db.VarChar(100)
  logo_path             String   @db.VarChar(255)
  icon_path             String   @db.VarChar(255)
  white_label_settings  Json     @default("{}")
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  customers             Customer[]

  @@map("companies")
}

model Customer {
  customer_id               Int      @id @default(autoincrement())
  company_id                Int
  customer_representative   String?  @db.VarChar(100)
  email                     String   @db.VarChar(100)
  phone                     String?  @db.VarChar(20)
  remark                    String?  @db.VarChar(255)
  password                  String?  @db.VarChar(255)
  company                   Company  @relation(fields: [company_id], references: [company_id], onDelete: Cascade)
  ems_units                 EmsUnit[]

  @@unique([company_id, email])
  @@index([company_id])
  @@map("customers")
}

model EmsUnit {
  id                  BigInt    @id @default(autoincrement())
  unit_id             String    @unique @db.VarChar(64)
  customer_id         Int?
  location_label      String?   @db.VarChar(120)
  latitude            Decimal?  @db.Decimal(10, 6)
  longitude           Decimal?  @db.Decimal(10, 6)
  device_type         String?   @db.VarChar(120)
  last_seen_at        DateTime?
  topic_path          String?   @db.VarChar(255)
  unit_field_template Json
  rtu_overrides       Json
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  customer            Customer? @relation(fields: [customer_id], references: [customer_id], onDelete: SetNull)
  logs                EmsLog[]

  @@index([customer_id])
  @@index([last_seen_at])
  @@map("ems_units")
}

model EmsLog {
  id              BigInt   @id @default(autoincrement())
  ems_unit_id     BigInt
  device_timestamp DateTime
  raw_unit_payload Json
  raw_rtu_array    Json
  mapped_rtu_array Json
  created_at       DateTime @default(now())
  ems_unit         EmsUnit  @relation(fields: [ems_unit_id], references: [id], onDelete: Cascade)

  @@index([ems_unit_id, device_timestamp(sort: Desc)])
  @@index([created_at])
  @@map("ems_logs")
}
